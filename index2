function updateDonut(rows){var counts={};rows.forEach(function(r){counts[r.status]=(counts[r.status]||0)+1;});var labelMap={closed:"Closed",good:"Good (EP stage)",bad:"Bad",unknown:"Unknown/pending"};var top=Object.keys(counts).map(function(k){return{status:labelMap[k]||k,n:counts[k]};}).sort(function(a,b){return b.n-a.n;});if(CHARTS.donut)CHARTS.donut.destroy();CHARTS.donut=new Chart(document.getElementById("donutChart"),{type:"doughnut",data:{labels:top.map(function(s){return s.status;}),datasets:[{data:top.map(function(s){return s.n;}),backgroundColor:DCOLORS,borderWidth:2}]},options:{responsive:true,maintainAspectRatio:false,plugins:{legend:{display:false},tooltip:{callbacks:{label:function(c){return c.label+": "+c.parsed.toLocaleString();}}}}}});var lg=document.getElementById("donut-legend");var html="";top.forEach(function(s,i){html+='<div class="dl-row"><span class="dl-sq" style="background:'+DCOLORS[i%DCOLORS.length]+'"></span>'+s.status+" ("+s.n.toLocaleString()+")</div>";});lg.innerHTML=html;}
var SEG_KEY={partner:function(r){return r.partner;},trafficType:function(r){return r.trafficType;},widget:function(r){return r.widget;},debt:function(r){return r.debt;},phone:function(r){return r.phoneScore?"Score "+r.phoneScore:null;},addr:function(r){return r.addrScore?"Score "+r.addrScore:null;},state:function(r){return r.state;},campaign:function(r){return r.campaign;},adGroup:function(r){return r.adGroup;},landingPage:function(r){return r.landingPage==="Call Center"?null:r.landingPage;}};
var SEG_MIN={partner:30,trafficType:30,widget:30,debt:20,phone:15,addr:15,state:30,campaign:30,adGroup:30,landingPage:30};
function showSeg(id,btn){window._curSeg=id;document.querySelectorAll(".tab").forEach(function(t){t.classList.remove("on");});if(btn)btn.classList.add("on");else{var b=document.querySelector('.tab[data-seg="'+id+'"]');if(b)b.classList.add("on");}var rows=filteredRows();var result=aggregate(rows,SEG_KEY[id],SEG_MIN[id]);var sortKey=SEG_LABELS[id];result.rows.sort(function(a,b){if(id==="debt"){var ai=DEBT_ORDER.indexOf(a.key),bi=DEBT_ORDER.indexOf(b.key);return(ai===-1?99:ai)-(bi===-1?99:bi);}return b[sortKey]-a[sortKey];});var maxVal=Math.max.apply(null,result.rows.map(function(r){return r[sortKey];}).concat([10]));var html="";result.rows.forEach(function(row){var val=row[sortKey]||0;var w=Math.min(val/maxVal*100,100).toFixed(1);var col=val<maxVal*0.4?"#e34948":val>maxVal*0.8?"#1baf7a":"#2a78d6";html+='<div class="hbar-row"><div class="hbl">'+row.key+'</div>'+'<div class="hbt"><div class="hbf" style="width:'+w+'%;background:'+col+'">'+'<span class="hbp">'+val.toFixed(1)+'%</span></div></div>'+'<div class="hbn">n='+row.total.toLocaleString()+'</div></div>';});html+='<div class="insight">'+insightText(result,sortKey)+'</div>';document.getElementById("seg-body").innerHTML=html;}
function renderScenarios(){var maxRate=Math.max.apply(null,D.scenarios.map(function(s){return s.stat.rate*100;}).concat([14]));var TARGET=9.6;var html="";D.scenarios.forEach(function(s){var rate=s.stat.rate*100;var w=Math.min(rate/maxRate*100,100).toFixed(1);var tw=(TARGET/maxRate*100).toFixed(1);var isBaseline=s.label.indexOf("Baseline")!==-1;var col=isBaseline?"#73726c":(rate>=TARGET?"#1baf7a":"#2a78d6");var tick=rate>=TARGET?'<span style="color:#1baf7a;font-size:15px;margin-left:5px">\u2713</span>':'<span style="width:20px;display:inline-block"></span>';html+='<div class="sc-row"><div class="sc-lbl">'+s.label+'<span>n='+s.stat.n.toLocaleString()+(s.detail?" \u00b7 "+s.detail:"")+'</span></div>'+'<div class="sc-track"><div class="sc-fill" style="width:'+w+'%;background:'+col+'">'+'<span class="sc-pct">'+rate.toFixed(1)+'%</span></div>'+'<div class="sc-mark" style="left:'+tw+'%"></div></div>'+tick+'</div>';});document.getElementById("scenario-body").innerHTML=html;}
function renderAll(){var rows=filteredRows();updateKPIs(computeSummary(rows));updateTrend(rows);updateDonut(rows);showSeg(window._curSeg||"partner",null);}document.addEventListener("DOMContentLoaded",function(){populateFilters();document.querySelectorAll(".tab").forEach(function(t){t.addEventListener("click",function(){showSeg(t.getAttribute("data-seg"),t);});});["f-partner","f-debt","f-month","f-state"].forEach(function(id){document.getElementById(id).addEventListener("change",renderAll);});document.getElementById("reset-btn").addEventListener("click",function(){["f-partner","f-debt","f-month","f-state"].forEach(function(id){document.getElementById(id).value="";});renderAll();});renderAll();renderScenarios();});</script>
